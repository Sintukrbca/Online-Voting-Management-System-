<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Login - Indian Voting System</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Indian Vote System</div>
        </div>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="#" onclick="showAdmin()">Admin</a></li>
            <li><a href="#" onclick="showVoter()">Voter</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container" style="max-width: 400px">
        <div class="card india-card">

            <h2 id="formTitle" style="text-align:center; color:#0047AB;">Voter Login</h2>

            <% if (error) { %>
                <p style="color:red; text-align:center;">
                    <%= error %>
                </p>
                <% } %>



                    <!-- VOTER FORM -->
                    <form id="voterForm" action="/send-otp" method="POST">
                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" name="username" required />
                        </div>

                        <div class="form-group">
                            <label for="voterId">Voter ID</label>
                            <input type="text" name="voterId" id="voterId" required />
                        </div>

                        <div class="form-group">
                            <label for="phone">Phone Number</label>
                            <input type="text" name="phone" id="phone" required />
                        </div>

                        <button type="submit" class="btn india-btn-primary" style="width:100%;">
                            Voter Login
                        </button>
                          <p style="text-align:center;">Don't have an account? <a href="/register">Register</a></p>
                    </form>

                    <form id="adminForm" action="/admin-login" method="POST" style="display:none;">
                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" name="username" required />
                        </div>

                        <div class="form-group">
                            <label>Password</label>
                            <input type="password" name="password" required />
                        </div>

                        <div class="form-group">
                            <label>Role</label>
                            <input type="text" name="role" value="admin" readonly />
                        </div>

                        <button type="submit" class="btn india-btn-primary" style="width:100%;">
                            Admin Login
                        </button>
                    </form>

        </div>
    </div>

    <script>
        function showAdmin() {
            document.getElementById("formTitle").innerText = "Admin Login";
            document.getElementById("adminForm").style.display = "block";
            document.getElementById("voterForm").style.display = "none";
        }
        
        function showVoter() {
            document.getElementById("formTitle").innerText = "Voter Login";
            document.getElementById("adminForm").style.display = "none";
            document.getElementById("voterForm").style.display = "block";
        } 
    </script>

</body>

</html>