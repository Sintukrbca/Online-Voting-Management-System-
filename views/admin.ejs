<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Admin Panel - Indian Voting System</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Admin Panel 🛡️</div>
        </div>
        <ul>

            <li><a href="/admin/candidates"> Manage Candidates</a></li>
            <li><a href="/admin/voters"> Manage Voters</a></li>
            <li><a href="/admin/result">View Results</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <div class="card india-card">
            <h3>➕ Add New Candidate</h3>
            <% if (typeof csuccess !=='undefined' && csuccess) { %>
                <p style="color:green; text-align:center;">
                    <%= csuccess %>
                </p>
                <% } %>

                    <form action="/admin/add-candidate" method="POST">
                        <div class="form-group">
                            <label>Candidate Name</label>
                            <input type="text" name="name" required />
                        </div>
                        <div class="form-group">
                            <label>Party</label>
                            <input type="text" name="party" required />
                        </div>
                        <button type="submit" class="btn india-btn-primary" style="width:100%">Add Candidate</button>
                    </form>
        </div>


        <div class="card india-card">
            <h3>➕ Add New Voter</h3>

            <% if (error) { %>
                <p style="color:red; text-align:center;">
                    <%= error %>
                </p>
                <% } %>

                    <% if (typeof success !=='undefined' && success) { %>
                        <p style="color:green; text-align:center;">
                            <%= success %>
                        </p>
                        <% } %>
                            <form action="/admin/add-voter" method="POST">
                                <div class="form-group">
                                    <label>Voter Name</label>
                                    <input type="text" name="username" required />
                                </div>
                                <div class="form-group">
                                    <label>Vote For</label>
                                    <input type="text" name="voterId" required />
                                </div>
                                <button type="submit" class="btn india-btn-primary" style="width:100%">Add
                                    Voter</button>
                            </form>
        </div>





    </div>

    <footer
        style="background-color: rgba(65, 64, 64, 0.639); color: #e3eaf6f5; text-align: center; padding: 1rem 0.5rem; margin-top: 1rem; box-shadow: 0 -4px 12px rgba(0, 71, 171, 0.3);">
        <p>&copy; 2026 India Voting System. All rights reserved.</p>
        <a style="text-decoration: none; color: #eae6ff; margin-right: 10px" href="/developers">Developers🌐 </a>
    </footer>

</body>

</html>