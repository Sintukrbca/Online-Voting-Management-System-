<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Manage Candidates - Admin Panel</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Admin Panel 🛡️</div>
        </div>
        <ul>
            <li><a href="/admin">Back to Admin</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <div class="card india-card">
            <h2>📋 Manage Candidates</h2>
            
            <% if (candidates && candidates.length > 0) { %>
                <table style="width:100%; border-collapse: collapse; margin-top:20px;">
                    <thead>
                        <tr style="background:#0047AB; color:white;">
                            <th style="padding:10px; border:1px solid #ddd;">Name</th>
                            <th style="padding:10px; border:1px solid #ddd;">Party</th>
                            <th style="padding:10px; border:1px solid #ddd;">Votes</th>
                            <th style="padding:10px; border:1px solid #ddd;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% candidates.forEach(candidate => { %>
                            <tr>
                                <td style="padding:10px; border:1px solid #ddd;"><%= candidate.name %></td>
                                <td style="padding:10px; border:1px solid #ddd;"><%= candidate.party %></td>
                                <td style="padding:10px; border:1px solid #ddd;"><%= candidate.votes %></td>
                                <td style="padding:10px; border:1px solid #ddd;">
                                    <a href="delete/<%= candidate._id %>" 
                                       onclick="return confirm('Are you sure you want to delete this candidate?')" 
                                       style="color:red; text-decoration:none;">🗑️ Delete</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p style="text-align:center; margin-top:20px;">No candidates found. <a href="/admin">Add some candidates</a></p>
            <% } %>
        </div>
    </div>

</body>
</html>