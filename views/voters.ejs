<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Manage Voters - Admin Panel</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Admin Panel 🛡️</div>
        </div>
        <ul>
            <li><a href="/admin">Back to Admin</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <div class="card india-card">
            <h2>👥 Manage Voters</h2>

            <% if (voters && voters.length> 0) { %>
                <div class="table-wrapper">

                    <table class="manage-table">

                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Voter ID</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% voters.forEach(v=>{ %>

                                <tr>
                                    <td>
                                        <%= v.username %>
                                    </td>

                                    <td>
                                        <%= v.voterId %>
                                    </td>
                                    <td>
                                        <%= v.status.charAt(0).toUpperCase() + v.status.slice(1) %>
                                    </td>
                                    <td>
                                        <a href="/admin/delete-voter/<%= v._id %>" class="btn btn-danger">Delete</a>
                                        <a href="/admin/edit?type=voter&id=<%= v._id %>" class="btn btn-edit">Edit</a>
                                    </td>

                                </tr>

                                <% }) %>

                        </tbody>

                    </table>

                </div>
                <% } else { %>
                    <p style="text-align:center; margin-top:20px;">No voters found. <a href="/admin">Add some voters</a>
                    </p>
                    <% } %>
        </div>
    </div>

</body>

</html>