<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Admin Panel - Indian Voting System</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Admin Panel 🛡️</div>
        </div>
        <ul>

            <li><a href="/">Home</a></li>
            <li><a href="login">Login</a></li>
        </ul>
    </nav>




    <div class="card india-card">
        <h3>➕ Add New Voter</h3>

        <% if (error) { %>
            <p style="color:red; text-align:center;">
                <%= error %>
            </p>
            <% } %>

                <% if (typeof success !=='undefined' && success) { %>
                    <p style="color:green; text-align:center;">
                        <%= success %>
                    </p>
                    <% } %>
                        <form action="/register" method="POST">
                            <div class="form-group">
                                <label>Voter Name</label>
                                <input type="text" name="username" required />
                            </div>
                            <div class="form-group">
                                <label>Vote For</label>
                                <input type="text" name="voterId" required />
                            </div>
                            <button type="submit" class="btn india-btn-primary" style="width:100%">Add
                                Voter</button>
                        </form>
    </div>





    </div>


</body>

</html>