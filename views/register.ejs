<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Admin Panel - Indian Voting System</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Indian Voting System</div>
        </div>
        <ul>

            <li><a href="/">Home</a></li>
            <li><a href="login">Login</a></li>
        </ul>
    </nav>




    <div class="card india-card">
        <h3>📝 Register Voter</h3>

        <p style="color:red; text-align:center;">
            <%= error %>
        </p>

        <form action="/register" method="POST" class="register-form">
            <div class="form-group">
                <label for="username">Voter Name</label>
                <input type="text" id="username" name="username" required />
            </div>
            <div class="form-group">
                <label for="voterId">Vote ID</label>
                <input type="text" id="voterId" name="voterId" required />
            </div>
            <div class="form-group">
                <label for="aadhar">Aadhar Number</label>
                <input type="text" id="aadhar" name="aadhar" required />
            </div>
            <div class="form-group">
                <label for="mobile">Mobile Number</label>
                <input type="text" id="mobile" name="mobile" required />
            </div>
            <div class="form-group">
                <label for="fatherName">Father's Name</label>
                <input type="text" id="fatherName" name="fatherName" required />
            </div>
            <div class="form-group">
                <label for="address">Address</label>
                <input type="text" id="address" name="address" required />
            </div>
            <div class="form-group">
                <label for="gender">Gender</label>
                <select id="gender" name="gender" required>
                    <option value="">Select Gender</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label for="dob">Date of Birth</label>
                <input type="date" id="dob" name="dob" required />
            </div>
            <div class="form-group">
                <label for="pincode">Pin Code</label>
                <input type="text" id="pincode" name="pincode" required />
            </div>
            <button type="submit" class="btn india-btn-primary login-submit-btn" style="grid-column: span 2;">Register
                Voter</button>
        </form>
    </div>

    </div>

</body>

</html>