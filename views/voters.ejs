<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/images/ovms-logo.png">
    <title>Manage Voters - Admin Panel</title>
    <link rel="stylesheet" href="/style.css" />
</head>

<body class="india-theme">

    <nav class="india-nav">
        <div class="nav-brand">
            <div class="ashoka-chakra">⊛</div>
            <div class="logo-text">Admin Panel 🛡️</div>
        </div>
        <ul>
            <li><a href="/admin">Back to Admin</a></li>
        </ul>
    </nav>

    <div class="flag-stripe"></div>

    <div class="container">
        <div class="card india-card">
            <h2>👥 Manage Voters</h2>

            <% if (voters && voters.length> 0) { %>
                <table style="width:100%; border-collapse: collapse; margin-top:20px;">
                    <thead>
                        <tr style="background:#0047AB; color:white;">
                            <th style="padding:10px; border:1px solid #ddd;">Username</th>
                            <th style="padding:10px; border:1px solid #ddd;">Voter ID</th>
                            <th style="padding:10px; border:1px solid #ddd;">Last Voted</th>
                            <th style="padding:10px; border:1px solid #ddd;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% voters.forEach(voter=> { %>
                            <tr>
                                <td style="padding:10px; border:1px solid #ddd;">
                                    <%= voter.username %>
                                </td>
                                <td style="padding:10px; border:1px solid #ddd;">
                                    <%= voter.voterId %>
                                </td>
                                <td style="padding:10px; border:1px solid #ddd;">
                                    <%= voter.lastVotedDate ? new Date(voter.lastVotedDate).toLocaleDateString()
                                        : 'Never' %>
                                </td>
                                <td style="padding:10px; border:1px solid #ddd;">
                                    <a href="/admin/delete-voter/<%= voter._id %>"
                                        onclick="return confirm('Are you sure you want to delete this voter?')"
                                        style="color:red; text-decoration:none;">🗑️ Delete</a>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } else { %>
                    <p style="text-align:center; margin-top:20px;">No voters found. <a href="/admin">Add some voters</a>
                    </p>
                    <% } %>
        </div>
    </div>

</body>

</html>